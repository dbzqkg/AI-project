<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lzh.mapper.LoginMapper">
    <update id="updateProfileHistory">
        UPDATE patient_profile
        SET history = #{history}
        WHERE id = #{id}
    </update>

    <select id="login" resultType="User">
        SELECT id, username, password FROM sys_user
        WHERE username = #{username} AND password = #{password}
    </select>
    <select id="getProfileById" resultType="com.lzh.pojo.PatientProfile">
        SELECT * FROM patient_profile
        WHERE id = #{id}
    </select>


</mapper>